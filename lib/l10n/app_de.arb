  },
  "tournamentSetupInfoSiteMapPdfBody": "Optionaler Plan des Spielgeländes (Felder, Anfahrt, Infrastruktur) zum Herunterladen.",
  "@tournamentSetupInfoSiteMapPdfBody": {
    "description": "Info dialog body for the site-map PDF upload"
  },
  "tournamentSetupInfoEntryFeeTitle": "Startgeld",
  "@tournamentSetupInfoEntryFeeTitle": {
    "description": "Info dialog title for the entry fee field"
  },
  "tournamentSetupInfoEntryFeeBody": "Betrag, den Teilnehmer zahlen. Leer oder 0 bedeutet kostenlos (\"Gratis\").",
  "@tournamentSetupInfoEntryFeeBody": {
    "description": "Info dialog body for the entry fee field"
  },
  "tournamentSetupInfoPaymentMethodsTitle": "Wie bezahlt wird",
  "@tournamentSetupInfoPaymentMethodsTitle": {
    "description": "Info dialog title for the payment methods chips"
  },
  "tournamentSetupInfoPaymentMethodsBody": "Wähle, welche Zahlungsarten du vor Ort akzeptierst (Bar, TWINT, Karte). Mehrfachauswahl möglich.",
  "@tournamentSetupInfoPaymentMethodsBody": {
    "description": "Info dialog body for the payment methods chips"
  },
  "tournamentSetupInfoContactTitle": "Kontakt für Rückfragen",
  "@tournamentSetupInfoContactTitle": {
    "description": "Info dialog title for the contact person fields"
  },
  "tournamentSetupInfoContactBody": "Name und Telefonnummer der Person, die Teilnehmer bei Fragen erreichen. Optional.",
  "@tournamentSetupInfoContactBody": {
    "description": "Info dialog body for the contact person fields"
  },
  "tournamentSetupInfoParticipantInfoTitle": "Hinweise für Teilnehmer",
  "@tournamentSetupInfoParticipantInfoTitle": {
    "description": "Info dialog title shared by the participant free-text info fields (food, travel, accommodation, weather)"
  },
  "tournamentSetupInfoParticipantInfoBody": "Freitextfelder für praktische Infos rund ums Turnier. Erscheinen in der Turnierbeschreibung; alle optional.",
  "@tournamentSetupInfoParticipantInfoBody": {
    "description": "Info dialog body shared by the participant free-text info fields"
  },
  "tournamentSetupInfoTeamSizeMinTitle": "Kleinste Teamgrösse",
  "@tournamentSetupInfoTeamSizeMinTitle": {
    "description": "Info dialog title for the minimum team size field on the participants step"
  },
  "tournamentSetupInfoTeamSizeMinBody": "Wie viele Spieler ein Team mindestens haben muss. Bei 1 spielen Einzelpersonen.",
  "@tournamentSetupInfoTeamSizeMinBody": {
    "description": "Info dialog body for the minimum team size field"
  },
  "tournamentSetupInfoMaxTeamSizeTitle": "Grösste Teamgrösse",
  "@tournamentSetupInfoMaxTeamSizeTitle": {
    "description": "Info dialog title for the maximum players per team field on the participants step"
  },
  "tournamentSetupInfoMaxTeamSizeBody": "Wie viele Spieler ein Team höchstens haben darf. Liegt dieser Wert über dem Minimum, sind Teams unterschiedlicher Grösse erlaubt.",
  "@tournamentSetupInfoMaxTeamSizeBody": {
    "description": "Info dialog body for the maximum players per team field"
  },
  "tournamentSetupInfoMaxParticipantsTitle": "Teilnehmer-Obergrenze",
  "@tournamentSetupInfoMaxParticipantsTitle": {
    "description": "Info dialog title for the maximum participants field on the participants step"
  },
  "tournamentSetupInfoMaxParticipantsBody": "Wie viele Teams höchstens mitspielen. Ist das Limit erreicht, kommen weitere Teams auf die Warteliste. Sie rücken Stück für Stück nach, sobald sich ein Team abmeldet oder von einer Person mit Setup-Berechtigung entfernt wird.",
  "@tournamentSetupInfoMaxParticipantsBody": {
    "description": "Info dialog body for the maximum participants field"
  },
  "tournamentSetupInfoFormatModeTitle": "Wie das Turnier aufgebaut ist",
  "@tournamentSetupInfoFormatModeTitle": {
    "description": "Info dialog title for the format-mode choice"
  },
  "tournamentSetupInfoFormatModeBody": "\"Klassisch\" führt durch den gewohnten Ablauf: eine Vorrunde und danach ein K.-o. \"Stufen-Graph\" ist für Fortgeschrittene: du baust den Turnierablauf aus einzelnen Stufen selbst zusammen und verbindest sie. Im Stufen-Graph-Modus entfällt der separate K.-o.-Schritt — die K.-o.-Stufen baust du direkt im Graphen.",
  "@tournamentSetupInfoFormatModeBody": {
    "description": "Info dialog body for the format-mode choice"
  },
  "tournamentSetupInfoVorrundeTitle": "Wie die Vorrunde läuft",
  "@tournamentSetupInfoVorrundeTitle": {
    "description": "Info dialog title for the Vorrunde type choice"
  },
  "tournamentSetupInfoVorrundeBody": "Bestimmt, wie gespielt wird, bevor das K.-o. beginnt. \"Gruppenphase\": jeder spielt in seiner Gruppe gegen jeden, die Bestplatzierten ziehen weiter. \"Schoch\": ein gemeinsamer Pool, die Paarungen werden nach jeder Runde neu nach Tabellenstand gebildet — gut für grosse Felder.",
  "@tournamentSetupInfoVorrundeBody": {
    "description": "Info dialog body for the Vorrunde type choice"
  },
  "tournamentSetupInfoKoTypeTitle": "Welcher K.-o.-Baum",
  "@tournamentSetupInfoKoTypeTitle": {
    "description": "Info dialog title for the KO type choice"
  },
  "tournamentSetupInfoKoTypeBody": "Steuert, wie das Ausscheiden funktioniert: bei \"einfach\" ist man nach einer Niederlage raus, bei \"doppelt\" erst nach der zweiten, und das \"Trostturnier\" gibt früh Ausgeschiedenen einen Nebenwettbewerb. Ausführliche Erklärung im \"K.-o.-Systeme erklärt\"-Sheet.",
  "@tournamentSetupInfoKoTypeBody": {
    "description": "Info dialog body for the KO type choice"
  },
  "tournamentSetupInfoKoBracketSizeTitle": "Wie viele Teams im K.-o.",
  "@tournamentSetupInfoKoBracketSizeTitle": {
    "description": "Info dialog title for the classic KO bracket-size selector"
  },
  "tournamentSetupInfoKoBracketSizeBody": "Wie viele Teams in den K.-o.-Baum kommen (eine Zweierpotenz: 2, 4, 8, 16, …). Bei Gruppenphase muss diese Zahl durch die Anzahl Gruppen teilbar sein, weil pro Gruppe gleich viele weiterkommen.",
  "@tournamentSetupInfoKoBracketSizeBody": {
    "description": "Info dialog body for the classic KO bracket-size selector"
  },
  "tournamentSetupInfoKoSeedingSourceTitle": "Woher die Setzliste kommt",
  "@tournamentSetupInfoKoSeedingSourceTitle": {
    "description": "Info dialog title for the classic KO seeding-source choice"
  },
  "tournamentSetupInfoKoSeedingSourceBody": "Automatisch aus Vorrunde: Die Setzliste für den K.-o.-Baum wird automatisch aus der Vorrunden-Rangliste gebildet. Du musst nichts von Hand sortieren.\n\nManuell: Du legst die Setzliste selbst fest. Das passiert nach der Vorrunde auf einem eigenen Setzlisten-Screen, wo du die Qualifikanten per Ziehen sortierst. Erst wenn die Setzliste gespeichert ist, lässt sich das K.-o. starten.",
  "@tournamentSetupInfoKoSeedingSourceBody": {
    "description": "Info dialog body for the classic KO seeding-source choice"
  },
  "tournamentSetupInfoKoMatchupTitle": "Wer gegen wen",
  "@tournamentSetupInfoKoMatchupTitle": {
    "description": "Info dialog title for the classic KO matchup choice"
  },
  "tournamentSetupInfoKoMatchupBody": "Bestimmt die Paarungen im K.-o.-Baum. \"Beste vs. Schlechteste\" lässt die stärksten gegen die schwächsten antreten, \"1. vs. 2.\" paart benachbarte Ränge.",
  "@tournamentSetupInfoKoMatchupBody": {
    "description": "Info dialog body for the classic KO matchup choice"
  },
  "tournamentSetupInfoKoTiebreakTitle": "Entscheid bei Gleichstand",
  "@tournamentSetupInfoKoTiebreakTitle": {
    "description": "Info dialog title for the classic KO tiebreak-method choice"
  },
  "tournamentSetupInfoKoTiebreakBody": "Wie ein unentschiedenes K.-o.-Spiel entschieden wird. \"Mighty-Finisher\" und \"Shoot-out\" sind dabei nicht dasselbe. Der Mighty-Finisher wird gespielt, wenn eine zeitbegrenzte Partie abläuft: der Finisher startet, sobald die Zeit abgelaufen ist, und der laufende Satz wird zu Ende gespielt. Steht es danach unentschieden, folgt ein Entscheidungssatz nach den festgelegten Finisher-Regeln. \"Klassisch\" ist der herkömmliche Entscheid ohne Zeit-Finisher. Das Shoot-out ist ein anderes Konzept (Übergang Vorrunde→K.-o. bei platzierungsrelevantem Unentschieden).",
  "@tournamentSetupInfoKoTiebreakBody": {
    "description": "Info dialog body for the classic KO tiebreak-method choice"
  },
  "tournamentSetupInfoKoConsolationDirectTitle": "Wer direkt im Trostturnier startet",
  "@tournamentSetupInfoKoConsolationDirectTitle": {
    "description": "Info dialog title for the consolation direct-starter count"
  },
  "tournamentSetupInfoKoConsolationDirectBody": "Wie viele Teams direkt aus der Vorrunde ins Trostturnier einsteigen, zusätzlich zu den im Hauptbaum ausgeschiedenen. \"Keine\" heisst: nur Ausgeschiedene aus dem Hauptbaum.",
  "@tournamentSetupInfoKoConsolationDirectBody": {
    "description": "Info dialog body for the consolation direct-starter count"
  },
  "tournamentSetupInfoKoConsolationNameTitle": "Name des Trostturniers",
  "@tournamentSetupInfoKoConsolationNameTitle": {
    "description": "Info dialog title for the consolation name field"
  },
  "tournamentSetupInfoKoConsolationNameBody": "Pflichtfeld beim Trostturnier: unter diesem Namen erscheint der Nebenwettbewerb. Ohne Namen kannst du nicht weiter.",
  "@tournamentSetupInfoKoConsolationNameBody": {
    "description": "Info dialog body for the consolation name field"
  },
  "tournamentSetupInfoKoRoundRulesTitle": "Regeln je Runde",
  "@tournamentSetupInfoKoRoundRulesTitle": {
    "description": "Info dialog title for the per-KO-round rule blocks"
  },
  "tournamentSetupInfoKoRoundRulesBody": "Pro K.-o.-Runde einstellbar: wie viele Sätze zum Sieg nötig sind, das Zeitlimit pro Spiel, die Pause danach und ob ein Tiebreak greift. Spätere Runden dürfen länger angesetzt sein als frühe.",
  "@tournamentSetupInfoKoRoundRulesBody": {
    "description": "Info dialog body for the per-KO-round rule blocks"
  },
  "tournamentSetupInfoMaxSetsTitle": "Sätze pro Spiel (Vorrunde)",
  "@tournamentSetupInfoMaxSetsTitle": {
    "description": "Info dialog title for the prelim max-sets field"
  },
  "tournamentSetupInfoMaxSetsBody": "Die höchstmögliche Anzahl Sätze, die ein Vorrunden-Spiel dauern darf. In der Vorrunde dürfen Spiele unentschieden enden; die Rangliste entscheidet über das Weiterkommen.",
  "@tournamentSetupInfoMaxSetsBody": {
    "description": "Info dialog body for the prelim max-sets field"
  },
  "tournamentSetupInfoGroupCountTitle": "In wie viele Gruppen",
  "@tournamentSetupInfoGroupCountTitle": {
    "description": "Info dialog title for the group-count field"
  },
  "tournamentSetupInfoGroupCountBody": "Wie viele Gruppen in der Gruppenphase gebildet werden. Aus jeder Gruppe ziehen gleich viele Teams ins K.-o. — diese Zahl muss zur K.-o.-Grösse passen (sie wird im nächsten Schritt geprüft).",
  "@tournamentSetupInfoGroupCountBody": {
    "description": "Info dialog body for the group-count field"
  },
  "tournamentSetupInfoGroupingStrategyTitle": "Wie Teams auf Gruppen verteilt werden",
  "@tournamentSetupInfoGroupingStrategyTitle": {
    "description": "Info dialog title for the grouping-strategy dropdown"
  },
  "tournamentSetupInfoGroupingStrategyBody": "Legt fest, nach welchem Prinzip die Teams den Gruppen zugeordnet werden. Reissverschluss: stärkste und schwächste Teams werden abwechselnd verteilt, damit die Gruppen etwa gleich stark sind. Blockweise: die Top-Teams werden der Reihe nach auf die Gruppen verteilt. Zufall: zufällige Verteilung, mit gesetztem Seed reproduzierbar.",
  "@tournamentSetupInfoGroupingStrategyBody": {
    "description": "Info dialog body for the grouping-strategy dropdown, covering all three options"
  },
  "tournamentSetupInfoRandomSeedTitle": "Startwert für die Zufallsverteilung",
  "@tournamentSetupInfoRandomSeedTitle": {
    "description": "Info dialog title for the random-seed field"
  },
  "tournamentSetupInfoRandomSeedBody": "Eine Zahl, die die zufällige Gruppierung steuerbar macht: derselbe Seed erzeugt immer dieselbe Verteilung. Lässt du das Feld leer, wird jedes Mal neu gemischt.",
  "@tournamentSetupInfoRandomSeedBody": {
    "description": "Info dialog body for the random-seed field"
  },
  "tournamentSetupInfoPitchAssignmentTitle": "Welche Felder für welche Gruppe",
  "@tournamentSetupInfoPitchAssignmentTitle": {
    "description": "Info dialog title for the per-group pitch assignment"
  },
  "tournamentSetupInfoPitchAssignmentBody": "Ordnet jeder Gruppe (A, B, C, …) die Felder zu, auf denen ihre Spiele laufen. Ein Feld darf mehreren Gruppen dienen. Nur in der Gruppenphase und nur, wenn du Felder angelegt hast.",
  "@tournamentSetupInfoPitchAssignmentBody": {
    "description": "Info dialog body for the per-group pitch assignment"
  },
  "tournamentSetupInfoSchochRoundsTitle": "Anzahl Schoch-Runden",
  "@tournamentSetupInfoSchochRoundsTitle": {
    "description": "Info dialog title for the Schoch rounds slider"
  },
  "tournamentSetupInfoSchochRoundsBody": "Wie viele Runden im Schoch-Modus gespielt werden. Mehr Runden trennen die Tabelle sauberer — bei grossen Feldern zu empfehlen. Die Paarungen jeder Runde entstehen live nach Tabellenstand.",
  "@tournamentSetupInfoSchochRoundsBody": {
