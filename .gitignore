# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
/android/build/

# Local-only project memory and AI tool configs (per ~/Workbench/CLAUDE.md)
/CLAUDE.md
.claude/
.cursor/
.copilot/

# Third-party rule documents (copyright respective associations)
/docs/rules/*.pdf

# Coverage reports
/coverage/

