# Local Supabase OAuth provider credentials.
# Copy this file to `.env` (gitignored) and fill in real values once you
# have OAuth apps set up. Until then the keypair-only auth path works.

# Google OAuth — created in Google Cloud Console
SUPABASE_AUTH_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_GOOGLE_SECRET=

# Apple OAuth — created in Apple Developer Portal
SUPABASE_AUTH_APPLE_CLIENT_ID=
SUPABASE_AUTH_APPLE_SECRET=
